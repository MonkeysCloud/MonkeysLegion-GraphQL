# ═══════════════════════════════════════════════════════════════
# MonkeysLegion GraphQL — Configuration
# ═══════════════════════════════════════════════════════════════
#
# Enterprise GraphQL engine for MonkeysLegion applications.
# Copy to config/graphql.mlc and adjust values as needed.

graphql {
    # ── HTTP Endpoints ──────────────────────────────────────
    endpoint          = "/graphql"
    graphiql_endpoint = "/graphiql"
    graphiql_enabled  = ${APP_DEBUG:true}

    # ── Schema Scanning ─────────────────────────────────────
    # Directories (relative to project root) containing
    # GraphQL types, queries, mutations, and subscriptions.
    scan_dirs      = ["app/GraphQL"]
    scan_namespace = "App\\GraphQL"

    # ── Security ────────────────────────────────────────────
    security {
        # Max query depth (0 = unlimited). Prevents deeply nested queries.
        max_depth = 10

        # Max query complexity (0 = unlimited). Prevents expensive queries.
        max_complexity = 1000

        # Introspection — disable in production to hide schema.
        introspection = ${APP_DEBUG:true}

        # Automatic Persisted Queries (APQ). Requires PSR-16 cache.
        persisted_queries = false

        # Rate limiting per client IP. Requires PSR-16 cache.
        rate_limit {
            max_requests   = 100
            window_seconds = 60
        }
    }

    # ── Schema Cache ────────────────────────────────────────
    # Enable in production for faster schema building.
    # Requires monkeyslegion-cache (PSR-16).
    cache {
        enabled = false
        ttl     = 3600
    }

    # ── Subscriptions (WebSocket) ───────────────────────────
    subscriptions {
        enabled   = false
        driver    = "memory"                                    # "memory" or "redis"
        host      = "0.0.0.0"
        port      = 6001
        redis_dsn = ${REDIS_DSN:redis://127.0.0.1:6379}
    }

    # ── Debug ───────────────────────────────────────────────
    # Shows stack traces and internal error details in responses.
    # NEVER enable in production.
    debug = ${APP_DEBUG:false}
}
