# ─────────────────────────────────────────────────────────────
# MonkeysLegion GraphQL — Configuration
# File: config/graphql.mlc
# ─────────────────────────────────────────────────────────────

# ── HTTP Endpoints ──────────────────────────────────────────
graphql.endpoint = "/graphql"
graphql.graphiql_endpoint = "/graphiql"
graphql.graphiql_enabled = true

# ── Schema Scanning ─────────────────────────────────────────
# Directories (relative to project root) where GraphQL types,
# queries, mutations, and subscriptions are defined.
graphql.scan_dirs = ["app/GraphQL"]
graphql.scan_namespace = "App\\GraphQL"

# ── Security ────────────────────────────────────────────────
# Max query depth (0 = unlimited). Prevents deeply nested queries.
graphql.security.max_depth = 10

# Max query complexity (0 = unlimited). Prevents expensive queries.
graphql.security.max_complexity = 1000

# Introspection — disable in production to hide your schema.
graphql.security.introspection = env("APP_DEBUG", true)

# Automatic Persisted Queries (APQ) — requires PSR-16 cache.
graphql.security.persisted_queries = false

# Rate limiting per client IP (requires PSR-16 cache).
graphql.security.rate_limit.max_requests = 100
graphql.security.rate_limit.window_seconds = 60

# ── Schema Cache ────────────────────────────────────────────
# Enable in production for faster schema building.
# Requires monkeyslegion-cache (PSR-16).
graphql.cache.enabled = env("APP_DEBUG", false)
graphql.cache.ttl = 3600

# ── Subscriptions (WebSocket) ───────────────────────────────
graphql.subscriptions.enabled = false
graphql.subscriptions.driver = "memory"        # "memory" or "redis"
graphql.subscriptions.host = "0.0.0.0"
graphql.subscriptions.port = 6001
graphql.subscriptions.redis_dsn = env("REDIS_DSN", "redis://127.0.0.1:6379")

# ── Debug ───────────────────────────────────────────────────
# Shows stack traces and internal error details in responses.
# NEVER enable in production.
graphql.debug = env("APP_DEBUG", false)
